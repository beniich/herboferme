# ═══════════════════════════════════════════════════════════════
# HERBUTE BACKEND — Environment Variables (Production Template)
# ═══════════════════════════════════════════════════════════════
#
# ⚠️  IMPORTANT: Copy to .env and fill in real values.
#     NEVER commit .env to version control!
#
# Source: SOC2 Production Checklist (06-PRODUCTION-CHECKLIST.md)
# ═══════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# SERVER
# ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=2065

# ────────────────────────────────────────────────────────────────
# DATABASE — MongoDB
# ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/herbute
# Production: MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/herbute?retryWrites=true

# ────────────────────────────────────────────────────────────────
# REDIS — Rate limiting, Cache, Sessions
# ────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Production avec password: REDIS_URL=redis://:password@host:6379

# ────────────────────────────────────────────────────────────────
# JWT — Asymmetric RS256 (recommandé)
# Générer les clés: openssl genrsa -out jwt.private.key 2048
#                  openssl rsa -in jwt.private.key -pubout -out jwt.public.key
# ────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/etc/secrets/jwt.private.key
JWT_PUBLIC_KEY_PATH=/etc/secrets/jwt.public.key
JWT_EXPIRY=24h

# Fallback HS256 pour développement local (si pas de clés RS256)
JWT_SECRET=CHANGE_ME_USE_A_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS_MINIMUM

# ────────────────────────────────────────────────────────────────
# CORS — Origines autorisées (séparées par virgule)
# ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production: ALLOWED_ORIGINS=https://herbute.com,https://app.herbute.com

# ────────────────────────────────────────────────────────────────
# SECURITY
# ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_MIN_32_CHARS

# ────────────────────────────────────────────────────────────────
# STRIPE — Paiements
# ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ESSENTIEL=price_xxx
STRIPE_PRICE_PROFESSIONNEL=price_xxx

# ────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ────────────────────────────────────────────────────────────────
# EMAIL — Notifications SMTP
# ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@herbute.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="Herbute <noreply@herbute.com>"
ADMIN_EMAIL=admin@herbute.com

# ────────────────────────────────────────────────────────────────
# FRONTEND
# ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://app.herbute.com

# ────────────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Options: debug | info | warn | error

SENTRY_DSN=
# Production: SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ────────────────────────────────────────────────────────────────
# STORAGE (S3 / Azure Blob / local)
# ────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
# Production: STORAGE_PROVIDER=s3
AWS_S3_BUCKET=herbute-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ────────────────────────────────────────────────────────────────
ENABLE_GOOGLE_AUTH=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_LOGGING=true

<!--
  ═══════════════════════════════════════════════════════════════
  soap-examples.xml — Exemples de requêtes SOAP prêts à l'emploi
  ═══════════════════════════════════════════════════════════════

  Comment utiliser ces exemples :
    1. SoapUI    : File > New SOAP Project > WSDL URL > /soap/auth?wsdl
    2. Postman   : New Request > Body > raw > XML > coller l'envelope
    3. cURL      : voir les commandes en bas de ce fichier
    4. Insomnia  : New Request > Body > XML

  Endpoint : POST http://localhost:2065/soap/auth
  Header   : Content-Type: text/xml; charset=utf-8
  Header   : SOAPAction: "http://herbute.ma/auth/{NomOperation}"
  ═══════════════════════════════════════════════════════════════
-->


<!-- ═══════════════════════════════════════════════════════
     OPÉRATION 1 : Login
     SOAPAction: "http://herbute.ma/auth/Login"
     ═══════════════════════════════════════════════════════ -->
<Login_Request>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope
  xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
  xmlns:auth="http://herbute.ma/auth">
  <soapenv:Header/>
  <soapenv:Body>
    <auth:LoginRequest>
      <auth:email>ahmed@ferme-albaraka.ma</auth:email>
      <auth:password>MonMotDePasse@1234!</auth:password>
    </auth:LoginRequest>
  </soapenv:Body>
</soapenv:Envelope>
</Login_Request>

<!-- Réponse attendue (succès) -->
<Login_Response_Success>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/">
  <soapenv:Body>
    <LoginResponse xmlns="http://herbute.ma/auth">
      <success>true</success>
      <message>Connecté avec succès.</message>
      <user>
        <id>64abc123def456</id>
        <email>ahmed@ferme-albaraka.ma</email>
        <nom>Benali</nom>
        <prenom>Ahmed</prenom>
        <role>proprietaire</role>
        <plan>professionnel</plan>
        <farmId>64farm789xyz</farmId>
        <lastLogin>2026-02-27T10:30:00.000Z</lastLogin>
      </user>
      <token>
        <accessToken>eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...</accessToken>
        <tokenType>Bearer</tokenType>
        <expiresIn>900</expiresIn>
        <expiresAt>2026-02-27T10:45:00.000Z</expiresAt>
      </token>
    </LoginResponse>
  </soapenv:Body>
</soapenv:Envelope>
</Login_Response_Success>

<!-- Réponse attendue (erreur — SOAP Fault) -->
<Login_Response_Fault>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/">
  <soapenv:Body>
    <soapenv:Fault>
      <faultcode>tns:INVALID_CREDENTIALS</faultcode>
      <faultstring>Identifiants invalides.</faultstring>
    </soapenv:Fault>
  </soapenv:Body>
</soapenv:Envelope>
</Login_Response_Fault>



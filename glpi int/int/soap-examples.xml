<!--
  ═══════════════════════════════════════════════════════════════
  COMMANDES cURL ÉQUIVALENTES
  ═══════════════════════════════════════════════════════════════

  # Login
  curl -X POST http://localhost:2065/soap/auth \
    -H "Content-Type: text/xml; charset=utf-8" \
    -H 'SOAPAction: "http://herbute.ma/auth/Login"' \
    -c cookies.txt \
    -d '<?xml version="1.0"?>
  <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:auth="http://herbute.ma/auth">
    <soapenv:Body>
      <auth:LoginRequest>
        <auth:email>ahmed@ferme.ma</auth:email>
        <auth:password>MonMotDePasse@1234!</auth:password>
      </auth:LoginRequest>
    </soapenv:Body>
  </soapenv:Envelope>'

  # GetCurrentUser (avec le token récupéré au login)
  curl -X POST http://localhost:2065/soap/auth \
    -H "Content-Type: text/xml; charset=utf-8" \
    -H 'SOAPAction: "http://herbute.ma/auth/GetCurrentUser"' \
    -b cookies.txt \
    -d '<?xml version="1.0"?>
  <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:auth="http://herbute.ma/auth">
    <soapenv:Body>
      <auth:GetCurrentUserRequest>
        <auth:accessToken>VOTRE_ACCESS_TOKEN_ICI</auth:accessToken>
      </auth:GetCurrentUserRequest>
    </soapenv:Body>
  </soapenv:Envelope>'

  # ValidateToken (rapide, sans DB)
  curl -X POST http://localhost:2065/soap/auth \
    -H "Content-Type: text/xml; charset=utf-8" \
    -H 'SOAPAction: "http://herbute.ma/auth/ValidateToken"' \
    -d '<?xml version="1.0"?>
  <soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:auth="http://herbute.ma/auth">
    <soapenv:Body>
      <auth:ValidateTokenRequest>
        <auth:accessToken>VOTRE_JWT_ICI</auth:accessToken>
      </auth:ValidateTokenRequest>
    </soapenv:Body>
  </soapenv:Envelope>'

  # Récupérer le WSDL
  curl http://localhost:2065/soap/auth?wsdl
  ═══════════════════════════════════════════════════════════════
-->

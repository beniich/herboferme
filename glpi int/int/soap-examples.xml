<!-- ═══════════════════════════════════════════════════════
     OPÉRATION 4 : RefreshToken
     SOAPAction: "http://herbute.ma/auth/RefreshToken"

     Deux cas :
     A) Client browser : cookie refresh_token envoyé automatiquement
        → laisser <refreshToken> vide
     B) Client enterprise (Java, C#) : passer le token explicitement
     ═══════════════════════════════════════════════════════ -->

<!-- Cas A : Browser (cookie HttpOnly automatique) -->
<RefreshToken_Request_Browser>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope
  xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
  xmlns:auth="http://herbute.ma/auth">
  <soapenv:Header/>
  <soapenv:Body>
    <auth:RefreshTokenRequest/>
  </soapenv:Body>
</soapenv:Envelope>
</RefreshToken_Request_Browser>

<!-- Cas B : Client Enterprise (token explicite) -->
<RefreshToken_Request_Enterprise>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope
  xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
  xmlns:auth="http://herbute.ma/auth">
  <soapenv:Header/>
  <soapenv:Body>
    <auth:RefreshTokenRequest>
      <auth:refreshToken>a3f4c8e2b1d9f7a6c5b4e3d2f1a0c9b8e7d6f5a4b3c2d1e0f9a8b7c6d5e4f3a2b1</auth:refreshToken>
    </auth:RefreshTokenRequest>
  </soapenv:Body>
</soapenv:Envelope>
</RefreshToken_Request_Enterprise>


<!-- ═══════════════════════════════════════════════════════
     OPÉRATION 5 : Logout
     SOAPAction: "http://herbute.ma/auth/Logout"
     ═══════════════════════════════════════════════════════ -->

<!-- Logout session courante -->
<Logout_Request_Single>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope
  xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
  xmlns:auth="http://herbute.ma/auth">
  <soapenv:Header/>
  <soapenv:Body>
    <auth:LogoutRequest>
      <auth:accessToken>eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...</auth:accessToken>
      <auth:logoutAll>false</auth:logoutAll>
    </auth:LogoutRequest>
  </soapenv:Body>
</soapenv:Envelope>
</Logout_Request_Single>

<!-- Logout toutes les sessions -->
<Logout_Request_All>
<?xml version="1.0" encoding="UTF-8"?>
<soapenv:Envelope
  xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
  xmlns:auth="http://herbute.ma/auth">
  <soapenv:Header/>
  <soapenv:Body>
    <auth:LogoutRequest>
      <auth:accessToken>eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...</auth:accessToken>
      <auth:logoutAll>true</auth:logoutAll>
    </auth:LogoutRequest>
  </soapenv:Body>
</soapenv:Envelope>
</Logout_Request_All>


